<nav class="navbar navbar-expand-lg navbar-light shadow-sm">
    <button class="btn btn-outline-dark btn-sm rounded-circle" id="menu-toggle">
        <i class="bi bi-list fs-5"></i>
    </button>

    <div class="d-flex align-items-center ms-auto">
        <div class="dropdown me-3">
            <div class="notification-bell" id="notifDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-bell fs-4"></i>
                @if (ViewBag.TinNhanMoi > 0)
                {
                        <span class="badge-pulse pulse-animation"></span>
                }
            </div>
            <ul class="dropdown-menu dropdown-menu-end dropdown-notifications p-0" aria-labelledby="notifDropdown">
                <li class="border-bottom d-flex justify-content-between align-items-center p-3">
                    <span class="fw-bold">Thông báo mới</span>
                    <span class="badge bg-primary rounded-pill">@ViewBag.TinNhanMoi</span>
                </li>
                <div style="max-height: 300px; overflow-y: auto;">
                    @if (ViewBag.TinNhanMoi > 0)
                    {
                            <a asp-controller="Chat" asp-action="Index" class="dropdown-item notification-item p-3">
                                <div class="d-flex align-items-center">
                                    <div class="bg-warning text-warning rounded-circle me-3 bg-opacity-10 p-2">
                                        <i class="bi bi-chat-left-text"></i>
                                    </div>
                                    <div>
                                        <p class="fw-bold small mb-0">Có tin nhắn mới</p>
                                        <small class="text-muted">Bạn có @ViewBag.TinNhanMoi tin nhắn mới.</small>
                                    </div>
                                </div>
                            </a>
                    }
                    else
                    {
                            <li class="text-muted p-4 text-center">
                                <small>Không có tin nhắn mới!</small>
                            </li>
                    }
                </div>
                <li><a class="dropdown-item small text-primary fw-bold border-top py-2 text-center" asp-controller="Chat" asp-action="Index">Xem tất cả</a></li>
            </ul>
        </div>

        <div class="fw-bold text-primary d-flex align-items-center">
            <span class="text-muted fw-normal small d-none d-md-inline me-2">Hệ thống Admin</span>
            <div class="bg-primary rounded-circle d-flex align-items-center justify-content-center text-white shadow-sm" style="width: 35px; height: 35px;">AD</div>
        </div>
    </div>
</nav>