<div id="sidebar-wrapper">
    <div class="sidebar-heading">Quản Lí Đoàn Viên</div>
    <div class="mt-3">
        <a asp-controller="Admin" asp-action="Index" class="sidebar-nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
            <i class="bi bi-speedometer2 me-2"></i> Tổng quan
        </a>
        <a asp-controller="Admin" asp-action="HoatDong" class="sidebar-nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "HoatDong" ? "active" : "")">
            <i class="bi bi-calendar-event me-2"></i> QL Hoạt động
        </a>
        <a asp-controller="Admin" asp-action="SinhVien" class="sidebar-nav-item @(ViewContext.RouteData.Values["Action"]?.ToString() == "SinhVien" ? "active" : "")">
            <i class="bi bi-people me-2"></i> QL Sinh viên
        </a>
        <a asp-controller="Chat" asp-action="Index" class="sidebar-nav-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Chat" ? "active" : "")">
            <i class="bi bi-chat-dots me-2"></i> Tin nhắn
        </a>
        <div class="border-top border-secondary mx-3 my-3 opacity-25"></div>
        <a asp-controller="Account" asp-action="Logout" class="sidebar-nav-item text-danger">
            <i class="bi bi-box-arrow-right me-2"></i> Đăng xuất
        </a>
    </div>
</div>