<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Đoàn Viên</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <style>
        body { overflow-x: hidden; }
        #wrapper { display: flex; width: 100%; height: 100vh; }
        #sidebar-wrapper {
            min-width: 250px;
            max-width: 250px;
            background-color: #212529; 
            color: white;
            transition: all 0.3s;
        }
        #sidebar-wrapper .list-group-item {
            background-color: transparent;
            color: #fff;
            border: none;
            padding: 15px 20px;
        }
        #sidebar-wrapper .list-group-item:hover {
            background-color: #343a40; /* Màu khi di chuột vào */
            color: #ffc107; /* Màu chữ khi hover */
        }
        #sidebar-wrapper .sidebar-heading {
            padding: 20px;
            font-size: 1.2rem;
            font-weight: bold;
            color: #ffc107;
            text-align: center;
            border-bottom: 1px solid #495057;
        }
        #page-content-wrapper {
            width: 100%;
            overflow-y: auto; /* Cho phép cuộn nội dung */
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <div id="sidebar-wrapper">
            <div class="sidebar-heading">Quản Lí Đoàn Viên</div>
            <div class="list-group list-group-flush mt-3">

                <a asp-controller="Admin" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-speedometer2 me-2"></i> Tổng quan
                </a>

                <a asp-controller="Admin" asp-action="HoatDong" class="list-group-item list-group-item-action">
                    <i class="bi bi-calendar-event me-2"></i> QL Hoạt động
                </a>

                <a asp-controller="Admin" asp-action="SinhVien" class="list-group-item list-group-item-action">
                    <i class="bi bi-people me-2"></i> QL Sinh viên
                </a>

                <a asp-controller="Chat" asp-action="Index" class="list-group-item list-group-item-action">
                    <i class="bi bi-chat-dots me-2"></i> Tin nhắn
                </a>

                <a asp-controller="Account" asp-action="Logout" class="list-group-item list-group-item-action text-danger">
                    <i class="bi bi-box-arrow-right"></i> Đăng xuất
                </a>
            </div>
        </div>

        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom px-4 shadow-sm">
                <button class="btn btn-outline-dark" id="menu-toggle"><i class="bi bi-list"></i></button>
                <div class="fw-bold text-primary ms-auto">
                    Xin chào, Admin!
                </div>
            </nav>

            <div class="container-fluid px-4 py-4">
                @RenderBody()
            </div>
        </div>
    </div>

   
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Script đơn giản để ẩn hiện Sidebar
        document.getElementById("menu-toggle").addEventListener("click", function(e) {
            e.preventDefault();
            var wrapper = document.getElementById("wrapper");
            var sidebar = document.getElementById("sidebar-wrapper");

            if (sidebar.style.marginLeft === "-250px") {
                 sidebar.style.marginLeft = "0";
            } else {
                 sidebar.style.marginLeft = "-250px";
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>