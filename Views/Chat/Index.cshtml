@model IEnumerable<DoanVienAPI.Models.ChatMessage>
@{
    ViewData["Title"] = "Phòng Chat Admin";
}

<div class="container mt-4">
    <div class="card border-0 shadow-lg" style="border-radius: 15px;">
        <div class="card-header bg-primary py-3 text-white" style="border-radius: 15px 15px 0 0;">
            <h5 class="d-flex align-items-center mb-0">
                <i class="bi bi-chat-dots-fill me-2"></i> 
                Hỗ trợ Sinh viên HUTECH
            </h5>
        </div>
        <div class="card-body bg-light">
            <div id="messagesList" class="mb-3 rounded border bg-white p-3" style="height: 450px; overflow-y: auto;">
                @if (Model != null && Model.Any())
                {
                    @foreach (var msg in Model)
                    {
                        var isMe = msg.User == "Admin" || msg.User == "Quản trị viên";
                                <div class="mb-3 @(isMe ? "text-end" : "text-start")">
                                    <div class="d-inline-block rounded p-2 shadow-sm @(isMe ? "bg-primary text-white" : "bg-light border text-dark")" style="max-width: 75%;">
                                        <div class="small fw-bold mb-1" style="font-size: 0.75rem;">@msg.User</div>
                                        <div style="word-wrap: break-word;">@msg.Message</div>
                                        <div class="mt-1 text-end" style="font-size: 0.65rem; opacity: 0.8;">
                                    @msg.Timestamp.ToString("HH:mm")
                                        </div>
                                    </div>
                                </div>
                    }
                }
                else
                {
                        <div id="no-msg-temp" class="text-muted small mt-5 text-center">Chưa có tin nhắn nào trong lịch sử...</div>
                }
            </div>

            <div class="input-group rounded shadow-sm">
                <span class="input-group-text border-end-0 fw-bold text-primary bg-white">Admin</span>
                <input type="text" id="messageInput" class="form-control border-start-0 py-2" placeholder="Nhập nội dung phản hồi..." autocomplete="off">
                <button id="sendButton" class="btn btn-primary px-4">
                    Gửi <i class="bi bi-send-fill ms-1"></i>
                </button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
       <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
         <script src="~/js/chathub.js"></script>
             <script>
            // Logic connection ở đây sẽ không còn báo lỗi nữa
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/chathub")
                .build();
            // ...
        </script>
}
