
@{
    ViewData["Title"] = "Tổng quan hệ thống";
}
<style>
    /* Định nghĩa màu Gradient cho các Card */
    .bg-grad-primary { background: linear-gradient(135deg, #4e73df 0%, #224abe 100%); }
    .bg-grad-success { background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%); }
    .bg-grad-warning { background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%); }

    /* Hiệu ứng cho Stat Card */
    .stat-card {
        border: none;
        border-radius: 15px;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
        min-height: 140px;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }

    /* Định vị Icon ẩn phía sau */
    .stat-icon {
        position: absolute;
        right: 15px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 4rem;
        opacity: 0.2; /* Làm mờ icon để tạo độ sang */
    }

    .card-title-custom {
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        opacity: 0.8;
    }

    .chart-box {
        border: none;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }
</style>

<div class="mb-4">
    <h2 class="fw-bold text-dark">🚀 Dashboard Thống Kê</h2>
    <p class="text-muted">Dữ liệu tổng hợp từ hệ thống Đoàn viên HUTECH.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card stat-card bg-grad-primary text-white shadow">
            <div class="card-body p-4">
                <div class="card-title-custom mb-2">Hoạt động Đoàn</div>
                <h2 class="display-5 fw-bold mb-0">@ViewBag.SoLuongHoatDong</h2>
                <i class="bi bi-calendar-check stat-icon"></i>
                <div class="small mt-3">
                    <a asp-action="HoatDong" class="text-decoration-none text-white">Xem danh sách <i class="bi bi-chevron-right"></i></a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card bg-grad-success text-white shadow">
            <div class="card-body p-4">
                <div class="card-title-custom mb-2">Lượt đăng ký tham gia</div>
                <h2 class="display-5 fw-bold mb-0">@ViewBag.SoLuongDangKy</h2>
                <i class="bi bi-person-badge stat-icon"></i>
                <div class="small mt-3">Cập nhật thời gian thực</div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card stat-card bg-grad-warning text-white shadow">
            <div class="card-body p-4">
                <div class="card-title-custom mb-2">Tổng số Sinh viên</div>
                <h2 class="display-5 fw-bold mb-0">@ViewBag.SoLuongSinhVien</h2>
                <i class="bi bi-people-fill stat-icon"></i>
                <div class="small mt-3">
                     <a asp-action="SinhVien" class="text-decoration-none text-white">Quản lý sinh viên <i class="bi bi-chevron-right"></i></a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card chart-box p-4">
            <h5 class="fw-bold mb-4">Tỷ lệ tương tác các hoạt động gần đây</h5>
            <canvas id="mainDashboardChart" style="max-height: 350px;"></canvas>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card chart-box p-4">
            <h5 class="fw-bold mb-4">Thông báo mới</h5>
            <div class="list-group list-group-flush">
                @if (ViewBag.ThongBaoMoi != null && ((List<HoatDong>)ViewBag.ThongBaoMoi).Any())
                {
                    @foreach (var item in (List<HoatDong>)ViewBag.ThongBaoMoi)
                    {
                        <div class="list-group-item border-0 px-0 py-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-primary rounded-3 me-3 flex-shrink-0 bg-opacity-10 p-2">
                                    <i class="bi bi-megaphone"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <h6 class="fw-bold text-truncate mb-0">@item.TenHoatDong</h6>
                                    @if (item.TrangThai == "DangDienRa")
                                    {
                                    <span class="badge bg-success" style="font-size: 0.6rem;">Đang diễn ra</span>
                                                        }
                                                        else if (item.TrangThai == "SapDienRa")
                                                        {
                                    <span class="badge bg-info" style="font-size: 0.6rem;">Sắp diễn ra</span>
                                    }
                                    <small class="text-muted">
                                           <i class="bi bi-calendar3 me-1"></i> @item.ThoiGianBatDau.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                <div class="py-4 text-center">
                    <p class="text-muted small">Chưa có thông báo nào mới.</p>
                </div>
                }
            </div>
            <button class="btn btn-outline-primary btn-sm rounded-pill mt-auto">Tất cả thông báo</button>
        </div>
    </div>
</div>

@section Scripts {
           <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>

            const chartLabels = @Html.Raw(ViewBag.ChartLabels ?? "[]"); 
            const chartData = @Html.Raw(ViewBag.ChartData ?? "[]");

            const ctx = document.getElementById('mainDashboardChart').getContext('2d');
            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: chartLabels, 
                    datasets: [{
                        label: 'Số lượng đăng ký',
                        data: chartData, 
                        backgroundColor: 'rgba(78, 115, 223, 0.8)',
                        borderRadius: 10,
                        barThickness: 25
                    }]
                },
                options: {
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, border: { display: false }, grid: { color: '#f0f0f0' } },
                        x: { border: { display: false }, grid: { display: false } }
                    }
                }
            });
        </script>
}