@model DoanVienAPI.Models.HoatDong

@{
    ViewData["Title"] = "Chỉnh sửa Hoạt động";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">✏️ Chỉnh sửa: @Model.TenHoatDong</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row">
                    <div class="col-md-8">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tên hoạt động</label>
                                <input asp-for="TenHoatDong" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Địa điểm</label>
                                <input asp-for="DiaDiem" class="form-control" required />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Bắt đầu</label>
                                <input asp-for="ThoiGianBatDau" class="form-control" type="datetime-local" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Kết thúc</label>
                                <input asp-for="ThoiGianKetThuc" class="form-control" type="datetime-local" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Điểm cộng</label>
                                <input asp-for="DiemCong" class="form-control" type="number" step="0.1" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Trạng thái</label>
                                <select asp-for="TrangThai" class="form-select">
                                    <option value="SapDienRa">Sắp diễn ra</option>
                                    <option value="DangDienRa">Đang diễn ra</option>
                                    <option value="DaKetThuc">Đã kết thúc</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-primary">Hình ảnh hoạt động</label>
                            <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewImage(this, 'editPreview')" />
                            <div class="mt-3 text-center">
                                <img id="editPreview" src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "/images/no-image.png" : Model.ImageUrl)" 
                                     class="img-thumbnail shadow-sm" style="max-height: 220px; width: 100%; object-fit: cover;" />
                                <small class="text-muted d-block mt-2">Ảnh hiện tại</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="4"></textarea>
                </div>

                <div class="border-top pt-3 text-end">
                    <a asp-action="HoatDong" class="btn btn-secondary px-4">Quay lại</a>
                    <button type="submit" class="btn btn-warning fw-bold px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
        <script src="~/js/activity-upload.js" asp-append-version="true"></script>
}