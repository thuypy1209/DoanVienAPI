@model DoanVienAPI.Models.HoatDong

@{
    ViewData["Title"] = "Chỉnh sửa Hoạt động";
}

@* HEADER TRANG *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">
        <i class="bi bi-pencil-square text-warning"></i> Chỉnh sửa Hoạt động
    </h2>
    <a asp-action="HoatDong" class="btn btn-outline-secondary rounded-pill shadow-sm">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 15px;">
    <div class="card-header border-0 bg-white px-4 pt-4">
        <h5 class="fw-bold text-muted mb-0">Thông tin hoạt động: <span class="text-primary">@Model.TenHoatDong</span></h5>
    </div>

    <div class="card-body p-4">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ImageUrl" />

            <div class="row">
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Tên hoạt động</label>
                            <input asp-for="TenHoatDong" class="form-control" placeholder="Nhập tên hoạt động..." required />
                            <span asp-validation-for="TenHoatDong" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Địa điểm</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                                <input asp-for="DiaDiem" class="form-control" placeholder="Địa điểm tổ chức..." required />
                            </div>
                            <span asp-validation-for="DiaDiem" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-success">Thời gian bắt đầu</label>
                            <input asp-for="ThoiGianBatDau" class="form-control" type="datetime-local" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-danger">Thời gian kết thúc</label>
                            <input asp-for="ThoiGianKetThuc" class="form-control" type="datetime-local" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Điểm cộng rèn luyện</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-star-fill text-warning"></i></span>
                                <input asp-for="DiemCong" class="form-control" type="number" step="0.1" />
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Trạng thái hiện tại</label>
                            <select asp-for="TrangThai" class="form-select">
                                <option value="SapDienRa">🟡 Sắp diễn ra</option>
                                <option value="DangDienRa">🟢 Đang diễn ra</option>
                                <option value="DaKetThuc">⚫ Đã kết thúc</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="col-md-4 border-start">
                    <div class="mb-3 px-3">
                        <label class="form-label fw-bold text-primary"><i class="bi bi-image"></i> Hình ảnh đại diện</label>
                        <input type="file" name="imageFile" class="form-control mb-3" accept="image/*" onchange="previewImage(this, 'editPreview')" />

                        <div class="position-relative">
                            <img id="editPreview" 
                                 src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/images/no-image.png") : Url.Content("~" + Model.ImageUrl))" 
                                 class="img-fluid rounded-3 border shadow-sm" 
                                 style="max-height: 250px; width: 100%; object-fit: cover;" />
                            <div class="position-absolute bg-dark small rounded-start bottom-0 end-0 bg-opacity-50 px-2 py-1 text-white">
                                Preview
                            </div>
                        </div>
                        <small class="text-muted d-block mt-2 text-center">Nên chọn ảnh tỉ lệ 16:9 để hiển thị đẹp nhất trên App</small>
                    </div>
                </div>
            </div>

            <div class="mb-3 mt-3">
                <label class="form-label fw-bold">Mô tả chi tiết hoạt động</label>
                <textarea asp-for="MoTa" class="form-control" rows="5" placeholder="Nội dung, yêu cầu, quyền lợi khi tham gia..."></textarea>
            </div>

            <div class="border-top pt-4 text-end">
                <button type="submit" class="btn btn-warning fw-bold rounded-pill px-5 shadow">
                    <i class="bi bi-floppy-fill me-1"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/activity-upload.js" asp-append-version="true"></script>
}