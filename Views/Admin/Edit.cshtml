@model DoanVienAPI.Models.HoatDong

@{
    ViewData["Title"] = "Chỉnh sửa Hoạt động";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">✏️ Chỉnh sửa: @Model.TenHoatDong</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên hoạt động</label>
                        <input asp-for="TenHoatDong" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Địa điểm</label>
                        <input asp-for="DiaDiem" class="form-control" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Bắt đầu</label>
                        <input asp-for="ThoiGianBatDau" class="form-control" type="datetime-local" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Kết thúc</label>
                        <input asp-for="ThoiGianKetThuc" class="form-control" type="datetime-local" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Điểm cộng</label>
                        <input asp-for="DiemCong" class="form-control" type="number" step="0.1" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Trạng thái</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="SapDienRa">Sắp diễn ra</option>
                            <option value="DangDienRa">Đang diễn ra</option>
                            <option value="DaKetThuc">Đã kết thúc</option>
                        </select>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                </div>

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-warning fw-bold px-4">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>