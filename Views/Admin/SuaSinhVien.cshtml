@model DoanVienAPI.Models.SinhVien
@{
    ViewData["Title"] = "Sửa Sinh viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-success">
        <i class="fa fa-user-edit"></i> Sửa Sinh viên
    </h2>

    <a asp-action="SinhVien" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card border-0 shadow-lg">
    <div class="card-body">
        <form asp-action="SuaSinhVien" method="post">

            <!-- VALIDATION -->
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <!-- hidden -->
            <input type="hidden" asp-for="Id" />

            <div class="row">

                <!-- LEFT -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label fw-bold">MSSV</label>
                        <input asp-for="MSSV" class="form-control bg-light" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên</label>
                        <input asp-for="HoTen" class="form-control bg-light" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Lớp</label>
                        <input asp-for="Lop" class="form-control" />
                        <span asp-validation-for="Lop" class="text-danger"></span>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Email</label>
                        <input asp-for="Email" type="email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Khoa</label>
                        <input asp-for="Khoa" class="form-control bg-light" readonly />
                    </div>

                </div>

            </div>

            <!-- ACTION -->
            <div class="border-top pt-3 text-end">
                <button type="submit" class="btn btn-success px-4">
                    <i class="fa fa-save"></i> Lưu thay đổi
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}