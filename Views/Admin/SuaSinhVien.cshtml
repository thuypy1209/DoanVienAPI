@model DoanVienAPI.Models.SinhVien
@{
    ViewData["Title"] = "Sửa Sinh viên";
    // Layout = "_Layout1"; // Nếu _ViewStart đã trỏ đúng thì không cần dòng này
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-success">
        <i class="bi bi-person-gear"></i> Sửa Sinh viên
    </h2>

    <a asp-action="SinhVien" class="btn btn-outline-secondary rounded-pill">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
</div>

@if (TempData["Error"] != null)
{
        <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card border-0 shadow-sm" style="border-radius: 15px;">
    <div class="card-body p-4">
        <form asp-action="SuaSinhVien" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">MSSV</label>
                        <input asp-for="MSSV" class="form-control bg-light" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên</label>
                        <input asp-for="HoTen" class="form-control bg-light" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Lớp</label>
                        <input asp-for="Lop" class="form-control" placeholder="Nhập lớp mới..." />
                        <span asp-validation-for="Lop" class="text-danger"></span>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Email</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="example@gmail.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Khoa</label>
                        <input asp-for="Khoa" class="form-control bg-light" readonly />
                    </div>
                </div>
            </div>

            <div class="border-top mt-3 pt-3 text-end">
                <button type="submit" class="btn btn-success rounded-pill px-4">
                    <i class="bi bi-floppy"></i> Lưu thay đổi
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
}