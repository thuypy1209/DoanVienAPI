@model DoanVienAPI.Models.SinhVien
@{
    ViewData["Title"] = "Sửa Sinh viên";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-success text-white">
            <h4 class="mb-0">Sửa Sinh viên mới</h4>
        </div>
        <div class="card-body">
            <form asp-action="SuaSinhVien">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">MSSV</label>
                        <input asp-for="MSSV" class="form-control" required />
                        <span asp-validation-for="MSSV" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Họ và tên</label>
                        <input asp-for="HoTen" class="form-control" required />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Lớp</label>
                        <input asp-for="Lop" class="form-control" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Khoa</label>
                        <input asp-for="Khoa" class="form-control" />
                    </div>
                </div>

                <div class="text-end">
                    <a asp-action="SinhVien" class="btn btn-secondary">Hủy</a>
                    <button type="submit" class="btn btn-success px-4">Lưu lại</button>
                </div>
            </form>
            <input type="hidden" asp-for="Id" />
        </div>
    </div>
</div>