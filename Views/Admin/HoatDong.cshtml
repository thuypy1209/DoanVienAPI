@model IEnumerable<HoatDong>

@{
    ViewData["Title"] = "Quản lý Hoạt động";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@* HEADER TRANG *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">
        <i class="bi bi-calendar-event-fill text-primary"></i> Danh sách Hoạt động
    </h2>

    <a asp-action="Create" class="btn btn-success rounded-pill px-4 shadow-sm">
        <i class="bi bi-plus-lg"></i> Tạo mới hoạt động
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 15px;">
    <div class="card-body p-4">

        <div class="input-group rounded-pill mb-4 overflow-hidden border shadow-sm">
            <span class="input-group-text border-0 bg-white"><i class="bi bi-search"></i></span>
            <input type="text" id="searchInput" class="form-control border-0"
                   placeholder="Tìm kiếm theo tên hoạt động, địa điểm..." onkeyup="searchTable()" />
        </div>

        <div class="table-responsive">
            <table class="table-hover border-top table align-middle">
                <thead class="table-light">
                    <tr class="text-secondary small">
                        <th class="ps-3">ID</th>
                        <th>Tên hoạt động / Địa điểm</th>
                        <th>Thời gian</th>
                        <th class="text-center">Điểm</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width: 200px;">Hành động</th>
                    </tr>
                </thead>

                <tbody id="activityTable">
                    @if (!Model.Any())
                    {
                            <tr>
                                <td colspan="6" class="text-muted fst-italic py-5 text-center">
                                    <i class="bi bi-calendar-x fs-2 d-block mb-2"></i> Chưa có hoạt động nào được tạo
                                </td>
                            </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                                    <tr>
                                        <td class="text-muted ps-3">#@item.Id</td>

                                        <td>
                                            <div class="fw-bold text-dark">@item.TenHoatDong</div>
                                            <div class="small text-muted"><i class="bi bi-geo-alt-fill text-danger"></i> @item.DiaDiem</div>
                                        </td>

                                        <td>
                                            <div class="small"><i class="bi bi-clock-history text-primary me-1"></i> @item.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")</div>
                                            <div class="small text-muted"><i class="bi bi-flag-fill text-secondary me-1"></i> @item.ThoiGianKetThuc.ToString("dd/MM/yyyy HH:mm")</div>
                                        </td>

                                        <td class="text-center">
                                            <span class="badge bg-danger text-danger rounded-pill bg-opacity-10 px-3">
                                                +@item.DiemCong
                                            </span>
                                        </td>

                                        <td class="text-center">
                                    @if (item.TrangThai == "SapDienRa")
                                    {
                                                    <span class="badge bg-warning text-warning border-warning rounded-pill border bg-opacity-10 px-3 py-2">
                                                        Sắp diễn ra
                                                    </span>
                                    }
                                    else if (item.TrangThai == "DangDienRa")
                                    {
                                                    <span class="badge bg-success text-success border-success rounded-pill border bg-opacity-10 px-3 py-2">
                                                        Đang diễn ra
                                                    </span>
                                    }
                                    else
                                    {
                                                    <span class="badge bg-secondary text-secondary border-secondary rounded-pill border bg-opacity-10 px-3 py-2">
                                                        Đã kết thúc
                                                    </span>
                                    }
                                        </td>

                                        <td class="text-center">
                                            <div class="btn-group rounded-pill overflow-hidden bg-white shadow-sm">
                                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-white text-info border-end" title="Xem">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <button class="btn btn-sm btn-white text-dark border-end" 
                                                        onclick="showQrCode(@item.Id, '@item.TenHoatDong')" title="Mã QR">
                                                    <i class="bi bi-qr-code"></i>
                                                </button>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-white text-warning border-end" title="Sửa">
                                                    <i class="bi bi-pencil-square"></i>
                                                </a>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-white text-danger" 
                                                   onclick="return confirm('Bạn có chắc chắn muốn xóa hoạt động này?');" title="Xóa">
                                                    <i class="bi bi-trash3"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="qrModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-dark border-0 text-white" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold" id="qrTitle">
                    <i class="bi bi-qr-code-scan text-warning me-2"></i> Mã QR Điểm danh
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body py-5 text-center">
                <div class="d-inline-block rounded-4 border bg-white p-4 shadow-sm">
                    <img id="qrImage" src="" style="width: 250px; image-rendering: pixelated;" />
                </div>
                <h4 id="activityLabel" class="fw-bold text-primary mt-4"></h4>
                <p class="text-muted small">
                    <i class="bi bi-phone me-1"></i> Sinh viên dùng App Đoàn Viên để quét mã này
                </p>
            </div>

            <div class="modal-footer justify-content-center border-0 pb-4">
                <button class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary rounded-pill px-4 shadow" onclick="printQr()">
                    <i class="bi bi-printer me-1"></i> In mã QR
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <script src="~/js/activity-qr.js" asp-append-version="true"></script>
        <script>
            function searchTable() {
                let input = document.getElementById("searchInput").value.toLowerCase();
                let rows = document.querySelectorAll("#activityTable tr");
                rows.forEach(row => {
                    row.style.display = row.innerText.toLowerCase().includes(input) ? "" : "none";
                });
            }
        </script>
}