@model IEnumerable<HoatDong>

@{
    ViewData["Title"] = "Danh sách Hoạt động";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">
        <i class="fa fa-calendar"></i> Danh sách Hoạt động
    </h2>

    <a asp-action="Create" class="btn btn-success">
        <i class="fa fa-plus"></i> Tạo mới
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">

        <!-- SEARCH (optional nâng cấp) -->
        <div class="mb-3">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="🔍 Tìm theo tên hoạt động..." onkeyup="searchTable()" />
        </div>

        <table class="table-hover table-bordered table align-middle">
            <thead class="table-primary text-center">
                <tr>
                    <th>ID</th>
                    <th>Tên hoạt động</th>
                    <th>Thời gian</th>
                    <th>Địa điểm</th>
                    <th>Điểm</th>
                    <th>Trạng thái</th>
                    <th style="width: 220px;">Hành động</th>
                </tr>
            </thead>

            <tbody id="activityTable">
                @if (!Model.Any())
                {
                        <tr>
                            <td colspan="7" class="text-muted fst-italic text-center">
                                Chưa có hoạt động nào
                            </td>
                        </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                                <tr>
                                    <td class="text-center">@item.Id</td>

                                    <td class="fw-bold text-primary">
                                @item.TenHoatDong
                                    </td>

                                    <td>
                                        <div class="small">
                                            <i class="fa fa-play text-success"></i>
                                    @item.ThoiGianBatDau.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                        <div class="small text-muted">
                                            <i class="fa fa-stop text-danger"></i>
                                    @item.ThoiGianKetThuc.ToString("dd/MM/yyyy HH:mm")
                                        </div>
                                    </td>

                                    <td>
                                        <i class="fa fa-map-marker-alt text-danger"></i>
                                @item.DiaDiem
                                    </td>

                                    <td class="fw-bold text-danger text-center">
                                        +@item.DiemCong
                                    </td>

                                    <td class="text-center">
                                @if (item.TrangThai == "SapDienRa")
                                {
                                                <span class="badge bg-warning text-dark px-3 py-2">
                                                    🟡 Sắp diễn ra
                                                </span>
                                }
                                else if (item.TrangThai == "DangDienRa")
                                {
                                                <span class="badge bg-success px-3 py-2">
                                                    🟢 Đang diễn ra
                                                </span>
                                }
                                else
                                {
                                                <span class="badge bg-secondary px-3 py-2">
                                                    ⚫ Đã kết thúc
                                                </span>
                                }
                                    </td>

                                    <td class="text-center">
                                        <a asp-action="Details"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-info text-white"
                                           title="Chi tiết">
                                            <i class="fa fa-eye"></i>
                                        </a>

                                        <button class="btn btn-sm btn-dark"
                                                onclick="showQrCode(@item.Id, '@item.TenHoatDong')"
                                                title="QR">
                                            <i class="fa fa-qrcode"></i>
                                        </button>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Sửa">
                                            <i class="fa fa-edit"></i>
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Bạn có chắc chắn muốn xóa?');"
                                           title="Xóa">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                    }
                }
            </tbody>
        </table>

    </div>
</div>

<!-- QR MODAL -->
<div class="modal fade" id="qrModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"id="qrTitle">
                    <i class="fa fa-qrcode"></i> Mã QR Điểm danh
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body text-center">
                <div class="bg-light d-inline-block rounded border p-3">
                    <img id="qrImage" src="" style="width: 250px;" />
                </div>
                <p class="text-muted fst-italic mt-3">
                    Quét bằng App Đoàn Viên
                </p>
            </div>

            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
                <button class="btn btn-primary" onclick="printQr()">
                    <i class="fa fa-print"></i> In
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
        <script src="~/js/activity-qr.js" asp-append-version="true"></script>
}