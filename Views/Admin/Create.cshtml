@model HoatDong

@{
    ViewData["Title"] = "Tạo Hoạt động mới";
}

@* HEADER TRANG *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">
        <i class="bi bi-calendar-plus text-primary"></i> Tạo Hoạt động mới
    </h2>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm">
        <i class="bi bi-arrow-left"></i> Quay lại danh sách
    </a>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 15px;">
    <div class="card-body p-4">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            @* VALIDATION SUMMARY *@
            <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

            <div class="row">
                @* CỘT BÊN TRÁI *@
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên hoạt động</label>
                        <input asp-for="TenHoatDong" class="form-control" placeholder="Nhập tên hoạt động..." required />
                        <span asp-validation-for="TenHoatDong" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa điểm tổ chức</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-geo-alt"></i></span>
                            <input asp-for="DiaDiem" class="form-control" placeholder="Ví dụ: Hội trường A, Sân trường..." required />
                        </div>
                        <span asp-validation-for="DiaDiem" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-primary">Hình ảnh hoạt động</label>
                        <input type="file" name="imageFile" class="form-control mb-3" accept="image/*" onchange="previewImage(this, 'imagePreview')" />

                        <div class="bg-light rounded-3 border p-3 text-center">
                            <img id="imagePreview"
                                 src="/images/no-image.png"
                                 class="img-fluid rounded shadow-sm"
                                 style="max-height: 150px; object-fit: cover;" />
                            <small class="text-muted d-block mt-2">Xem trước hình ảnh</small>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-success">Bắt đầu</label>
                            <input asp-for="ThoiGianBatDau" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ThoiGianBatDau" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold text-danger">Kết thúc</label>
                            <input asp-for="ThoiGianKetThuc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ThoiGianKetThuc" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                @* CỘT BÊN PHẢI *@
                <div class="col-md-6">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Điểm cộng rèn luyện</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light"><i class="bi bi-star-fill text-warning"></i></span>
                            <input asp-for="DiemCong" type="number" class="form-control" min="0" placeholder="0.0" />
                        </div>
                        <span asp-validation-for="DiemCong" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Trạng thái khởi tạo</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="SapDienRa">🟡 Sắp diễn ra</option>
                            <option value="DangDienRa">🟢 Đang diễn ra</option>
                            <option value="DaKetThuc">⚫ Đã kết thúc</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả hoạt động</label>
                        <textarea asp-for="MoTa" class="form-control" rows="8" placeholder="Viết mô tả chi tiết về hoạt động tại đây..."></textarea>
                    </div>
                </div>
            </div>

            @* ACTION BUTTONS *@
            <div class="border-top mt-4 pt-3 text-end">
                <button type="reset" class="btn btn-light rounded-pill me-2 px-4">Làm mới</button>
                <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">
                    <i class="bi bi-check-circle-fill me-1"></i> Lưu hoạt động
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/activity-upload.js" asp-append-version="true"></script>
}