@model HoatDong

@{
    ViewData["Title"] = "Thêm mới";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-primary">Tạo Hoạt động mới</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="fa fa-arrow-left"></i> Quay lại
    </a>
</div>

<div class="card border-0 shadow-lg">
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">

            <!-- VALIDATION SUMMARY -->
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="row">

                <!-- LEFT -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên hoạt động</label>
                        <input asp-for="TenHoatDong" class="form-control" placeholder="Nhập tên hoạt động..." />
                        <span asp-validation-for="TenHoatDong" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa điểm</label>
                        <input asp-for="DiaDiem" class="form-control" placeholder="Ví dụ: Hội trường A..." />
                        <span asp-validation-for="DiaDiem" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Hình ảnh hoạt động</label>
                        <input type="file" name="imageFile" class="form-control" accept="image/*" onchange="previewImage(this)" />

                        <div class="mt-2 text-center">
                            <img id="imagePreview"
                                 src="/images/activites/no-image.png"
                                 class="img-thumbnail shadow-sm"
                                 style="max-height: 150px;" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Bắt đầu</label>
                            <input asp-for="ThoiGianBatDau" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ThoiGianBatDau" class="text-danger"></span>
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label fw-bold">Kết thúc</label>
                            <input asp-for="ThoiGianKetThuc" type="datetime-local" class="form-control" />
                            <span asp-validation-for="ThoiGianKetThuc" class="text-danger"></span>
                        </div>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="col-md-6">

                    <div class="mb-3">
                        <label class="form-label fw-bold">Điểm cộng</label>
                        <input asp-for="DiemCong" type="number" class="form-control" min="0" />
                        <span asp-validation-for="DiemCong" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Trạng thái</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="SapDienRa">🟡 Sắp diễn ra</option>
                            <option value="DangDienRa">🟢 Đang diễn ra</option>
                            <option value="DaKetThuc">⚫ Đã kết thúc</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả</label>
                        <textarea asp-for="MoTa" class="form-control" rows="6"></textarea>
                    </div>

                </div>
            </div>

            <!-- ACTION -->
            <div class="mt-4 text-end">
                <button type="submit" class="btn btn-success px-4">
                    <i class="fa fa-save"></i> Lưu hoạt động
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/activity-upload.js" asp-append-version="true"></script>
}